{
  "name": "vscode-data-bridge",
  "displayName": "VSCode Data Bridge",
  "description": "%extension.description%",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.106.0"
  },
  "categories": [
    "Other",
    "Data Science",
    "Notebooks"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:dataBridge.controlCenter",
    "onCommand:dataBridge.startServer",
    "onCommand:dataBridge.stopServer",
    "onCommand:dataBridge.showStatus",
    "onCommand:dataBridge.copyServerConfig",
    "onCommand:dataBridge.openControlCenter",
    "onCommand:dataBridge.refreshControlCenter",
    "onCommand:dataBridge.listCommands",
    "onCommand:dataBridge.runNotebookCommand",
    "onCommand:dataBridge.executeCellByIndex"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dataBridge.openControlCenter",
        "title": "%command.openControlCenter%"
      },
      {
        "command": "dataBridge.refreshControlCenter",
        "title": "%command.refreshControlCenter%"
      },
      {
        "command": "dataBridge.startServer",
        "title": "%command.startServer%"
      },
      {
        "command": "dataBridge.stopServer",
        "title": "%command.stopServer%"
      },
      {
        "command": "dataBridge.showStatus",
        "title": "%command.showStatus%"
      },
      {
        "command": "dataBridge.copyServerConfig",
        "title": "%command.copyServerConfig%"
      },
      {
        "command": "dataBridge.listCommands",
        "title": "%command.listCommands%"
      },
      {
        "command": "dataBridge.runNotebookCommand",
        "title": "%command.runNotebookCommand%"
      },
      {
        "command": "dataBridge.executeCellByIndex",
        "title": "%command.executeCellByIndex%"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dataBridgeSidebar",
          "title": "%viewContainer.title%",
          "icon": "media/data-bridge.svg"
        }
      ]
    },
    "views": {
      "dataBridgeSidebar": [
        {
          "type": "webview",
          "id": "dataBridge.controlCenter",
          "name": "%view.controlCenter%"
        }
      ]
    },
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "dataBridge.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "%config.host.description%"
        },
        "dataBridge.port": {
          "type": "number",
          "default": 8765,
          "description": "%config.port.description%"
        },
        "dataBridge.portSpan": {
          "type": "number",
          "default": 20,
          "description": "%config.portSpan.description%"
        },
        "dataBridge.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "%config.autoStart.description%"
        },
        "dataBridge.followTargetCell": {
          "type": "boolean",
          "default": true,
          "description": "%config.followTargetCell.description%"
        },
        "dataBridge.controlCenterAutoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "%config.controlCenterAutoRefresh.description%"
        },
        "dataBridge.controlCenterRefreshIntervalMs": {
          "type": "number",
          "default": 3000,
          "description": "%config.controlCenterRefreshIntervalMs.description%"
        },
        "dataBridge.token": {
          "type": "string",
          "default": "",
          "description": "%config.token.description%"
        },
        "dataBridge.allowArbitraryCommands": {
          "type": "boolean",
          "default": false,
          "description": "%config.allowArbitraryCommands.description%"
        },
        "dataBridge.allowedCommandPrefixes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "jupyter.",
            "notebook.",
            "interactive.",
            "workbench.action.notebook.",
            "ipynb.",
            "vscode.executeData"
          ],
          "description": "%config.allowedCommandPrefixes.description%"
        }
      }
    }
  },
  "scripts": {
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.0"
  }
}
